# Copy to .env and fill in real values. Never commit .env.

LOG_LEVEL=INFO

# RabbitMQ (URL-encode default vhost as %2F)
# Example: amqp://USER:PASSWORD@host:5672/%2F
RABBITMQ_URL=

UPLOAD_DIR=/path/to/uploaded
STORAGE_PHOTO_PATH=/path/to/StoragePhoto
STORAGE_PATH=/path/to/Storage

FOTOLAB_KEY=change-me

# Secret for /upload and /multiuser test forms (must match client)
TEST_FORM_SEKRET=change-me

# Companion (see COMPANION_SETUP.md)
COMPANION_PORT=3020
COMPANION_PROTOCOL=http
COMPANION_DOMAIN=localhost:3020
COMPANION_SECRET=change-me-min-32-chars-random
COMPANION_ALLOWED_HOSTS=http://localhost:8000,http://localhost:3020

COMPANION_GOOGLE_KEY=
COMPANION_GOOGLE_SECRET=
COMPANION_DROPBOX_KEY=
COMPANION_DROPBOX_SECRET=
COMPANION_ONEDRIVE_KEY=
COMPANION_ONEDRIVE_SECRET=

COMPANION_MAX_FILE_SIZE=100MB
COMPANION_LOG_LEVEL=info

MULTIUSER_ALLOWED_IDS=
