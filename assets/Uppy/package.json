{
  "name": "uppy-bundle",
  "version": "1.0.0",
  "description": "Uppy bundle for imagelab service",
  "type": "module",
  "scripts": {
    "build": "esbuild src/uppy-bundle.js --bundle --format=iife --global-name=UppyBundle --outfile=dist/uppy-bundle.js --minify",
    "build:dev": "esbuild src/uppy-bundle.js --bundle --format=iife --global-name=UppyBundle --outfile=dist/uppy-bundle.js --sourcemap",
    "watch": "esbuild src/uppy-bundle.js --bundle --format=iife --global-name=UppyBundle --outfile=dist/uppy-bundle.js --watch"
  },
  "dependencies": {
    "@uppy/core": "^5.1.1",
    "@uppy/dashboard": "^5.1.0",
    "@uppy/drop-target": "^4.1.0",
    "@uppy/dropbox": "^5.1.0",
    "@uppy/google-drive": "^5.1.0",
    "@uppy/google-photos-picker": "^1.1.0",
    "@uppy/onedrive": "^5.1.0",
    "@uppy/tus": "^5.1.0",
    "@uppy/url": "^5.1.0",
    "@uppy/webcam": "^5.1.0",
    "@uppy/xhr-upload": "^5.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.19.0"
  }
}
